---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/astro/Navbar.astro';
import Footer from '../../../components/astro/Footer.astro';
import InsightPage from '../../../components/react/insights/InsightPage';
import { getAllInsightSlugs, getInsightData } from '../../../data/insights/registry';

export function getStaticPaths() {
  return getAllInsightSlugs().map((slug) => ({
    params: { slug },
    props: { slug },
  }));
}

const { slug } = Astro.props;
const data = getInsightData(slug)!;
---

<Layout
  title={`${data.meta.title} | FastCI Labs`}
  description={data.meta.shortDescription}
>
  <Navbar />

  <main class="pt-24 md:pt-32 pb-16 md:pb-24">
    <InsightPage
      client:load
      meta={data.meta}
      benchmarks={data.benchmarks}
    />
  </main>

  <Footer />
</Layout>
