---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/astro/Navbar.astro';
import Footer from '../components/astro/Footer.astro';
import Hero from '../components/react/Hero';
import HowItWorks from '../components/react/HowItWorks';
import Features from '../components/react/Features';
import FastCILabs from '../components/react/FastCILabs';
import CTA from '../components/react/CTA';
---

<Layout>
  <Navbar />

  <main>
    <Hero client:load />
    <HowItWorks client:visible />
    <Features client:visible />
    <FastCILabs client:visible />
    <CTA client:visible />
  </main>

  <Footer />
</Layout>
