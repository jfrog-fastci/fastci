---
interface Props {
  title?: string;
  description?: string;
  /** Optional: override default OG image for this page (absolute URL or path from base) */
  image?: string;
  /** Optional: alt text for the OG image */
  imageAlt?: string;
}

const {
  title = 'FastCI - Automatically Identify and Optimize Your CI',
  description = 'A drop-in agent for GitHub Actions that automatically identifies CI bottlenecks and generates fixes. Turn CI maintenance from reactive to proactive.',
  image,
  imageAlt = 'FastCI - Automatically Identify and Optimize Your CI',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const basePath = (import.meta.env.BASE_URL || '/').replace(/\/?$/, '/');
const baseUrl = new URL(basePath, Astro.site);
// Use 1200x630 - the universal standard for Slack, WhatsApp, Telegram, LinkedIn, Discord, Twitter, GitHub, etc.
const ogImageUrl = image
  ? image.startsWith('http') ? image : new URL(image.replace(/^\//, ''), baseUrl).href
  : new URL('og-image.png', baseUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/favicon.svg`} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph: Facebook, LinkedIn, Slack, WhatsApp, Telegram, Discord, iMessage, etc. -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="FastCI" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:type" content="image/png" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
